---
import Base from '../layouts/Base.astro';

const jsRules = [
  { id: 'js/no-eval', cwe: 'CWE-95', desc: 'Use of eval() allows arbitrary code execution', severity: 'critical' },
  { id: 'js/no-hardcoded-secret', cwe: 'CWE-798', desc: 'Hardcoded secret or credential detected', severity: 'high' },
  { id: 'js/no-sql-injection', cwe: 'CWE-89', desc: 'SQL injection via string concatenation or template literal', severity: 'critical' },
  { id: 'js/no-xss-innerhtml', cwe: 'CWE-79', desc: 'Assignment to innerHTML may lead to XSS', severity: 'high' },
  { id: 'js/no-command-injection', cwe: 'CWE-78', desc: 'Command injection via exec/spawn with dynamic input', severity: 'critical' },
  { id: 'js/no-document-write', cwe: 'CWE-79', desc: 'document.write() with dynamic content enables XSS', severity: 'high' },
  { id: 'js/no-open-redirect', cwe: 'CWE-601', desc: 'Open redirect via user-controlled URL', severity: 'medium' },
  { id: 'js/no-weak-crypto', cwe: 'CWE-327', desc: 'Use of weak cryptographic hash (MD5/SHA1)', severity: 'medium' },
  { id: 'js/no-path-traversal', cwe: 'CWE-22', desc: 'Path traversal via unsanitized user input', severity: 'high' },
  { id: 'js/no-prototype-pollution', cwe: 'CWE-1321', desc: 'Prototype pollution via object merge', severity: 'high' },
  { id: 'js/no-unsafe-regex', cwe: 'CWE-1333', desc: 'ReDoS-vulnerable regular expression', severity: 'medium' },
  { id: 'js/no-cors-star', cwe: 'CWE-942', desc: 'Permissive CORS policy (Access-Control-Allow-Origin: *)', severity: 'medium' },
];

const pyRules = [
  { id: 'py/no-eval', cwe: 'CWE-95', desc: 'Use of eval()/exec() allows arbitrary code execution', severity: 'critical' },
  { id: 'py/no-hardcoded-secret', cwe: 'CWE-798', desc: 'Hardcoded secret or credential detected', severity: 'high' },
  { id: 'py/no-sql-injection', cwe: 'CWE-89', desc: 'SQL injection via string formatting', severity: 'critical' },
  { id: 'py/no-command-injection', cwe: 'CWE-78', desc: 'Command injection via os.system/subprocess', severity: 'critical' },
  { id: 'py/no-path-traversal', cwe: 'CWE-22', desc: 'Path traversal via unsanitized user input', severity: 'high' },
  { id: 'py/no-weak-crypto', cwe: 'CWE-327', desc: 'Use of weak cryptographic hash (MD5/SHA1)', severity: 'medium' },
  { id: 'py/no-pickle', cwe: 'CWE-502', desc: 'Deserialization of untrusted data via pickle', severity: 'high' },
  { id: 'py/no-yaml-load', cwe: 'CWE-502', desc: 'Unsafe yaml.load() without SafeLoader', severity: 'high' },
  { id: 'py/no-debug-true', cwe: 'CWE-489', desc: 'DEBUG=True left enabled in production config', severity: 'medium' },
  { id: 'py/no-open-redirect', cwe: 'CWE-601', desc: 'Open redirect via user-controlled URL', severity: 'medium' },
  { id: 'py/no-cors-star', cwe: 'CWE-942', desc: 'Permissive CORS policy (CORS_ALLOW_ALL_ORIGINS)', severity: 'medium' },
];

const goRules = [
  { id: 'go/no-sql-injection', cwe: 'CWE-89', desc: 'SQL injection via string concatenation or fmt.Sprintf', severity: 'critical' },
  { id: 'go/no-command-injection', cwe: 'CWE-78', desc: 'Command injection via exec.Command with dynamic input', severity: 'critical' },
  { id: 'go/no-hardcoded-secret', cwe: 'CWE-798', desc: 'Hardcoded secret or credential detected', severity: 'high' },
  { id: 'go/no-weak-crypto', cwe: 'CWE-327', desc: 'Use of weak cryptographic hash (MD5/SHA1)', severity: 'medium' },
  { id: 'go/no-ssrf', cwe: 'CWE-918', desc: 'SSRF via http.Get/http.Post with variable URL', severity: 'high' },
];

const totalRules = jsRules.length + pyRules.length + goRules.length;

function severityColor(s: string) {
  if (s === 'critical') return 'var(--red)';
  if (s === 'high') return '#f97316';
  if (s === 'medium') return 'var(--yellow)';
  return 'var(--text-dim)';
}
---

<Base title="foxguard - Blazing fast security linter">

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-badge">Written in Rust</div>
      <h1 class="hero-title">foxguard</h1>
      <p class="hero-tagline">The <strong>Ruff</strong> of security. Blazing fast security linter.</p>

      <div class="terminal">
        <div class="terminal-bar">
          <span class="terminal-dot" style="background:#ef4444"></span>
          <span class="terminal-dot" style="background:#eab308"></span>
          <span class="terminal-dot" style="background:#22c55e"></span>
          <span class="terminal-title">terminal</span>
        </div>
        <div class="terminal-body">
          <div class="terminal-line">
            <span class="t-prompt">$</span> <span class="t-cmd">foxguard .</span>
          </div>
          <div class="terminal-line t-dim">
            Scanning 1,247 files...
          </div>
          <div class="terminal-line">
            <br />
          </div>
          <div class="terminal-line">
            <span class="t-file">src/auth/login.js</span><span class="t-pos">:14:5</span>
          </div>
          <div class="terminal-line t-indent">
            <span class="t-sev t-critical">critical</span>
            <span class="t-rule">js/no-sql-injection</span>
            <span class="t-cwe">CWE-89</span>
          </div>
          <div class="terminal-line t-indent t-dim">
            SQL query built with template literal interpolation
          </div>
          <div class="terminal-line">
            <br />
          </div>
          <div class="terminal-line">
            <span class="t-file">src/utils/config.py</span><span class="t-pos">:7:1</span>
          </div>
          <div class="terminal-line t-indent">
            <span class="t-sev t-high">high</span>
            <span class="t-rule">py/no-hardcoded-secret</span>
            <span class="t-cwe">CWE-798</span>
          </div>
          <div class="terminal-line t-indent t-dim">
            Hardcoded secret in 'api_key'
          </div>
          <div class="terminal-line">
            <br />
          </div>
          <div class="terminal-line">
            <span class="t-file">cmd/server.go</span><span class="t-pos">:42:3</span>
          </div>
          <div class="terminal-line t-indent">
            <span class="t-sev t-high">high</span>
            <span class="t-rule">go/no-ssrf</span>
            <span class="t-cwe">CWE-918</span>
          </div>
          <div class="terminal-line t-indent t-dim">
            Potential SSRF via http.Get with variable URL
          </div>
          <div class="terminal-line">
            <br />
          </div>
          <div class="terminal-line t-summary">
            Found <span class="t-accent">3 issues</span> in <span class="t-accent">1,247 files</span> <span class="t-dim">(0.84s)</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Speed -->
  <section class="section" id="speed">
    <div class="container">
      <h2 class="section-title">100x faster than Semgrep</h2>
      <p class="section-sub">Benchmark: scanning 10,000 files, {totalRules} rules</p>

      <div class="chart">
        <div class="chart-row">
          <span class="chart-label">foxguard</span>
          <div class="chart-bar-wrap">
            <div class="chart-bar chart-bar-fox" style="width: 4%">
              <span class="chart-val">0.8s</span>
            </div>
          </div>
        </div>
        <div class="chart-row">
          <span class="chart-label">Semgrep</span>
          <div class="chart-bar-wrap">
            <div class="chart-bar chart-bar-other" style="width: 85%">
              <span class="chart-val">82s</span>
            </div>
          </div>
        </div>
        <div class="chart-row">
          <span class="chart-label">ESLint</span>
          <div class="chart-bar-wrap">
            <div class="chart-bar chart-bar-other" style="width: 100%">
              <span class="chart-val">96s</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="section" id="features">
    <div class="container">
      <h2 class="section-title">Features</h2>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">&#127760;</div>
          <h3>Multi-language</h3>
          <p>JavaScript/TypeScript, Python, and Go. More languages coming soon.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">&#128737;</div>
          <h3>{totalRules} security rules</h3>
          <p>Injection, XSS, secrets, crypto, SSRF, path traversal. All mapped to CWEs.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">&#128202;</div>
          <h3>SARIF output</h3>
          <p>Native SARIF support for GitHub Code Scanning and CI integration.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">&#9889;</div>
          <h3>Zero config</h3>
          <p>No config files, no setup. Just run <code>foxguard .</code> and go.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Install -->
  <section class="section" id="install">
    <div class="container">
      <h2 class="section-title">Install</h2>
      <div class="install-grid">
        <div class="install-card">
          <div class="install-label">Rust / Cargo</div>
          <div class="code-block">
            <code>cargo install foxguard</code>
            <button class="copy-btn" data-copy="cargo install foxguard" aria-label="Copy">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            </button>
          </div>
        </div>
        <div class="install-card">
          <div class="install-label">npm / npx</div>
          <div class="code-block">
            <code>npx foxguard</code>
            <button class="copy-btn" data-copy="npx foxguard" aria-label="Copy">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Rules -->
  <section class="section" id="rules">
    <div class="container">
      <h2 class="section-title">Rules</h2>
      <p class="section-sub">{totalRules} rules across 3 languages, each mapped to a CWE identifier</p>

      <div class="rules-groups">
        {[
          { name: 'JavaScript / TypeScript', rules: jsRules, count: jsRules.length },
          { name: 'Python', rules: pyRules, count: pyRules.length },
          { name: 'Go', rules: goRules, count: goRules.length },
        ].map((group) => (
          <details class="rules-group">
            <summary>
              <span class="rules-group-name">{group.name}</span>
              <span class="rules-group-count">{group.count} rules</span>
            </summary>
            <div class="rules-list">
              {group.rules.map((rule) => (
                <div class="rule-row">
                  <code class="rule-id">{rule.id}</code>
                  <span class="rule-sev" style={`color: ${severityColor(rule.severity)}`}>{rule.severity}</span>
                  <span class="rule-cwe">{rule.cwe}</span>
                  <span class="rule-desc">{rule.desc}</span>
                </div>
              ))}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-section">
    <div class="container cta">
      <h2 class="cta-title">Open source. MIT licensed.</h2>
      <p class="cta-sub">Star us on GitHub and help make codebases safer.</p>
      <a href="https://github.com/peaktwilight/foxguard" class="cta-btn" target="_blank" rel="noopener">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
        Star on GitHub
      </a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <span>MIT License</span>
      <span class="footer-sep">|</span>
      <span>Made by <a href="https://github.com/peaktwilight">Peak Twilight</a></span>
      <span class="footer-sep">|</span>
      <span>foxguard.dev</span>
    </div>
  </footer>

  <script>
    document.querySelectorAll('.copy-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const text = btn.getAttribute('data-copy') || '';
        navigator.clipboard.writeText(text);
        btn.classList.add('copied');
        setTimeout(() => btn.classList.remove('copied'), 1500);
      });
    });
  </script>
</Base>

<style>
  /* Layout */
  .container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section {
    padding: 5rem 0;
    border-top: 1px solid var(--border);
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .section-sub {
    color: var(--text-dim);
    margin-bottom: 2.5rem;
  }

  /* Hero */
  .hero {
    padding: 6rem 0 4rem;
    text-align: center;
  }

  .hero-badge {
    display: inline-block;
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--accent);
    border: 1px solid var(--accent);
    border-radius: 9999px;
    padding: 0.25rem 0.75rem;
    margin-bottom: 1.5rem;
    opacity: 0.8;
  }

  .hero-title {
    font-family: var(--mono);
    font-size: clamp(3rem, 10vw, 5.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 1rem;
    color: #fff;
  }

  .hero-tagline {
    font-size: 1.25rem;
    color: var(--text-dim);
    max-width: 480px;
    margin: 0 auto 3rem;
  }

  .hero-tagline strong {
    color: var(--text);
  }

  /* Terminal */
  .terminal {
    max-width: 640px;
    margin: 0 auto;
    border-radius: 8px;
    border: 1px solid var(--border);
    overflow: hidden;
    text-align: left;
    background: #0d0d0d;
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: #161616;
    border-bottom: 1px solid var(--border);
  }

  .terminal-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .terminal-title {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--text-dim);
    margin-left: auto;
    margin-right: auto;
  }

  .terminal-body {
    padding: 1rem 1.25rem;
    font-family: var(--mono);
    font-size: 0.8rem;
    line-height: 1.7;
  }

  .terminal-line {
    white-space: nowrap;
    overflow: hidden;
  }

  .t-prompt {
    color: var(--accent);
    margin-right: 0.5rem;
  }

  .t-cmd {
    color: #fff;
  }

  .t-dim {
    color: var(--text-dim);
  }

  .t-file {
    color: var(--blue);
  }

  .t-pos {
    color: var(--text-dim);
  }

  .t-indent {
    padding-left: 1rem;
  }

  .t-sev {
    font-weight: 600;
    margin-right: 0.5rem;
    text-transform: uppercase;
    font-size: 0.7rem;
  }

  .t-critical {
    color: var(--red);
  }

  .t-high {
    color: #f97316;
  }

  .t-rule {
    color: var(--text);
    margin-right: 0.5rem;
  }

  .t-cwe {
    color: var(--text-dim);
  }

  .t-summary {
    border-top: 1px solid var(--border);
    padding-top: 0.75rem;
    margin-top: 0.25rem;
  }

  .t-accent {
    color: var(--accent);
    font-weight: 600;
  }

  /* Speed chart */
  .chart {
    max-width: 600px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .chart-row {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .chart-label {
    font-family: var(--mono);
    font-size: 0.85rem;
    width: 90px;
    text-align: right;
    color: var(--text-dim);
    flex-shrink: 0;
  }

  .chart-bar-wrap {
    flex: 1;
    background: var(--bg-card);
    border-radius: 4px;
    overflow: hidden;
    height: 32px;
  }

  .chart-bar {
    height: 100%;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-right: 0.75rem;
    min-width: 60px;
    transition: width 1s ease;
  }

  .chart-bar-fox {
    background: var(--accent);
  }

  .chart-bar-other {
    background: #333;
  }

  .chart-val {
    font-family: var(--mono);
    font-size: 0.75rem;
    font-weight: 600;
    color: #fff;
  }

  /* Features */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.25rem;
  }

  .feature-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem;
    transition: border-color 0.2s;
  }

  .feature-card:hover {
    border-color: #2e2e2e;
  }

  .feature-icon {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .feature-card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: #fff;
  }

  .feature-card p {
    font-size: 0.875rem;
    color: var(--text-dim);
    line-height: 1.5;
  }

  .feature-card code {
    background: var(--bg);
    padding: 0.1em 0.35em;
    border-radius: 3px;
    font-size: 0.8rem;
    color: var(--accent);
  }

  /* Install */
  .install-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .install-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
  }

  .install-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
  }

  .code-block {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.75rem 1rem;
    font-family: var(--mono);
    font-size: 0.875rem;
    color: var(--accent);
  }

  .copy-btn {
    background: none;
    border: none;
    color: var(--text-dim);
    cursor: pointer;
    padding: 4px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    transition: color 0.2s;
  }

  .copy-btn:hover {
    color: var(--text);
  }

  .copy-btn.copied {
    color: var(--accent);
  }

  /* Rules */
  .rules-groups {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .rules-group {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }

  .rules-group summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    cursor: pointer;
    user-select: none;
    list-style: none;
    font-weight: 600;
  }

  .rules-group summary::-webkit-details-marker {
    display: none;
  }

  .rules-group summary::before {
    content: '\25B6';
    font-size: 0.6rem;
    margin-right: 0.75rem;
    color: var(--text-dim);
    transition: transform 0.2s;
  }

  .rules-group[open] summary::before {
    transform: rotate(90deg);
  }

  .rules-group-name {
    color: #fff;
  }

  .rules-group-count {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--text-dim);
    font-weight: 400;
  }

  .rules-list {
    border-top: 1px solid var(--border);
  }

  .rule-row {
    display: grid;
    grid-template-columns: 1fr auto auto 2fr;
    gap: 0.75rem;
    align-items: center;
    padding: 0.6rem 1.25rem;
    font-size: 0.8rem;
    border-bottom: 1px solid #141414;
  }

  .rule-row:last-child {
    border-bottom: none;
  }

  .rule-id {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--accent);
  }

  .rule-sev {
    font-family: var(--mono);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  .rule-cwe {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--text-dim);
  }

  .rule-desc {
    color: var(--text-dim);
    font-size: 0.8rem;
  }

  /* CTA */
  .cta-section {
    text-align: center;
  }

  .cta-title {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: #fff;
  }

  .cta-sub {
    color: var(--text-dim);
    margin-bottom: 2rem;
  }

  .cta-btn {
